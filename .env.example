# Public URL
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/decomer

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Session secret (generate with: openssl rand -base64 32)
NUXT_SESSION_PASSWORD=your-32-char-minimum-secret

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Maps
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Resend (email API for magic link auth)
RESEND_API_KEY=re_your_api_key

# MercadoPago (payment gateway)
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
NUXT_PUBLIC_BASE_URL=http://localhost:3000
