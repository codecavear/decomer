{
  "name": "decomer",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "node .output/server/index.mjs",
    "start:migrate": "node scripts/migrate.mjs && node .output/server/index.mjs",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "bun run scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run server/database/seed.ts",
    "db:seed:viandas": "bun run scripts/seed-viandas-prod.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --project e2e",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.82",
    "@iconify-json/simple-icons": "^1.2.63",
    "@nuxt/content": "^3.9.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/i18n": "^10.2.1",
    "@standard-schema/spec": "^1.1.0",
    "@vueuse/nuxt": "^14.1.0",
    "better-sqlite3": "^12.6.2",
    "cloudinary": "^2.9.0",
    "drizzle-orm": "^0.45.1",
    "mercadopago": "^2.12.0",
    "nuxt": "^4.2.2",
    "nuxt-auth-utils": "^0.5.26",
    "postgres": "^3.4.8",
    "zod": "^4.2.1",
    "@vite-pwa/nuxt": "^0.10.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@types/google.maps": "^3.58.1",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.2.1"
  },
  "lint-staged": {
    "*.{vue,ts,js,mjs,cjs}": "eslint --fix"
  },
  "packageManager": "bun@1.3.4"
}